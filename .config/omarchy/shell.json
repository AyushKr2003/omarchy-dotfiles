{
  "version": 1,
  "idle": {
    "screensaver": 150,
    "lock": 300
  },
  "bar": {
    "position": "top",
    "transparent": false,
    "centerAnchor": "local.clock",
    "layout": {
      "left": [
        {
          "id": "omarchy.menu"
        },
        {
          "id": "omarchy.workspaces"
        },
        {
          "id": "omarchy.media"
        }
      ],
      "center": [
        {
          "id": "local.clock",
          "format": "dddd hh:mm AP",
          "formatAlt": "d MMMM 'W'ww yyyy",
          "verticalFormat": "hh\n—\nmm\nAP"
        },
        {
          "id": "local.weather",
          "unit": "metric",
          "location": "Patna"
        },
        {
          "id": "omarchy.system-update"
        },
        {
          "id": "omarchy.indicators"
        }
      ],
      "right": [
        {
          "id": "omarchy.tray"
        },
        {
          "id": "omarchy.bluetooth"
        },
        {
          "id": "omarchy.network"
        },
        {
          "id": "local.sysstat"
        },
        {
          "id": "omarchy.audio"
        },
        {
          "id": "omarchy.monitor"
        },
        {
          "id": "omarchy.power"
        }
      ]
    }
  },
  "plugins": [
    {
      "id": "local.settings"
    },
    {
      "id": "local.overview"
    },
    {
      "id": "orbit"
    },
    {
      "id": "local.screenTranslator"
    }
  ]
}
