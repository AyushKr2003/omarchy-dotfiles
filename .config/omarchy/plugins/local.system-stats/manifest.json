{
  "schemaVersion": 1,
  "id": "local.system-stats",
  "name": "Local System Stats",
  "version": "1.0.0",
  "author": "Omarchy, local port",
  "description": "System stats bar widget with a detailed hardware panel.",
  "kinds": [
    "bar-widget"
  ],
  "entryPoints": {
    "barWidget": "Panel.qml"
  },
  "barWidget": {
    "displayName": "Local System Stats",
    "description": "CPU, GPU, memory, disk, and load details in a themed panel.",
    "category": "System",
    "allowMultiple": false,
    "defaults": {
      "refreshSeconds": 2,
      "diskPath": "/"
    },
    "schema": [
      {
        "key": "refreshSeconds",
        "type": "integer",
        "label": "Refresh seconds",
        "min": 1,
        "max": 60,
        "step": 1,
        "defaultValue": 2
      },
      {
        "key": "diskPath",
        "type": "string",
        "label": "Disk path",
        "defaultValue": "/"
      }
    ]
  }
}
