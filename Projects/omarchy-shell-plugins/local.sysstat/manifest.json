{
  "schemaVersion": 1,
  "id": "local.sysstat",
  "name": "Local Sysstat",
  "version": "1.0.0",
  "author": "AyushKr2003",
  "description": "Compact system stats bar widget with a detailed click panel.",
  "kinds": [
    "bar-widget"
  ],
  "entryPoints": {
    "barWidget": "Panel.qml"
  },
  "barWidget": {
    "displayName": "Local Sysstat",
    "description": "CPU, GPU, memory, and disk details in compact horizontal rows.",
    "category": "System",
    "allowMultiple": false,
    "defaults": {
      "refreshSeconds": 2,
      "diskPath": "/",
      "showGpu": true
    },
    "schema": [
      {
        "key": "refreshSeconds",
        "type": "integer",
        "label": "Refresh seconds",
        "min": 1,
        "max": 60,
        "step": 1,
        "defaultValue": 2
      },
      {
        "key": "diskPath",
        "type": "string",
        "label": "Disk path",
        "defaultValue": "/"
      },
      {
        "key": "showGpu",
        "type": "boolean",
        "label": "Show GPU row",
        "defaultValue": true
      }
    ]
  }
}
