{
  "vim": [
    {
      "section": "Global",
      "source": "vim.rtorr.com",
      "items": [
        {
          "keys": ":h[elp] {kw}",
          "description": "Open help for keyword"
        },
        {
          "keys": ":sav[eas] {file}",
          "description": "Save file as"
        },
        {
          "keys": ":clo[se]",
          "description": "Close current pane"
        },
        {
          "keys": ":ter[minal]",
          "description": "Open a terminal window"
        },
        {
          "keys": "K",
          "description": "Open man page for word under cursor"
        }
      ]
    },
    {
      "section": "Cursor movement",
      "source": "vim.rtorr.com",
      "items": [
        {
          "keys": "h / j / k / l",
          "description": "Move cursor left / down / up / right"
        },
        {
          "keys": "gj / gk",
          "description": "Move cursor down / up (multi-line text)"
        },
        {
          "keys": "H / M / L",
          "description": "Jump to top / middle / bottom of screen"
        },
        {
          "keys": "w / W",
          "description": "Forward to start of word / WORD"
        },
        {
          "keys": "e / E",
          "description": "Forward to end of word / WORD"
        },
        {
          "keys": "b / B",
          "description": "Backward to start of word / WORD"
        },
        {
          "keys": "ge / gE",
          "description": "Backward to end of word / WORD"
        },
        {
          "keys": "%",
          "description": "Jump to matching bracket"
        },
        {
          "keys": "0 / ^",
          "description": "Start of line / first non-blank char"
        },
        {
          "keys": "$ / g_",
          "description": "End of line / last non-blank char"
        },
        {
          "keys": "gg / G",
          "description": "First / last line of document"
        },
        {
          "keys": "{N}gg / {N}G",
          "description": "Go to line N"
        },
        {
          "keys": "gd / gD",
          "description": "Go to local / global declaration"
        },
        {
          "keys": "fx / Fx",
          "description": "Jump to next / prev occurrence of x"
        },
        {
          "keys": "tx / Tx",
          "description": "Jump before next / after prev x"
        },
        {
          "keys": "; / ,",
          "description": "Repeat f/t/F/T forward / backward"
        },
        {
          "keys": "} / {",
          "description": "Jump to next / prev paragraph or block"
        },
        {
          "keys": "zz / zt / zb",
          "description": "Center / top / bottom cursor on screen"
        },
        {
          "keys": "Ctrl + E / Ctrl + Y",
          "description": "Scroll screen down / up one line"
        },
        {
          "keys": "Ctrl + D / Ctrl + U",
          "description": "Scroll down / up half page"
        },
        {
          "keys": "Ctrl + F / Ctrl + B",
          "description": "Scroll down / up full page"
        }
      ]
    },
    {
      "section": "Insert mode",
      "source": "vim.rtorr.com",
      "items": [
        {
          "keys": "i / I",
          "description": "Insert before cursor / start of line"
        },
        {
          "keys": "a / A",
          "description": "Append after cursor / end of line"
        },
        {
          "keys": "o / O",
          "description": "New line below / above current"
        },
        {
          "keys": "ea",
          "description": "Append at end of word"
        },
        {
          "keys": "Ctrl + H",
          "description": "Delete char before cursor"
        },
        {
          "keys": "Ctrl + W",
          "description": "Delete word before cursor"
        },
        {
          "keys": "Ctrl + T / Ctrl + D",
          "description": "Indent / de-indent line"
        },
        {
          "keys": "Ctrl + N / Ctrl + P",
          "description": "Autocomplete next / prev match"
        },
        {
          "keys": "Ctrl + Rx",
          "description": "Insert contents of register x"
        },
        {
          "keys": "Ctrl + Ox",
          "description": "Execute one normal-mode command x"
        },
        {
          "keys": "Esc / Ctrl + C",
          "description": "Exit insert mode"
        }
      ]
    },
    {
      "section": "Editing",
      "source": "vim.rtorr.com",
      "items": [
        {
          "keys": "r / R",
          "description": "Replace single char / enter replace mode"
        },
        {
          "keys": "J / gJ",
          "description": "Join line below with / without space"
        },
        {
          "keys": "g~ / gu / gU",
          "description": "Toggle / lower / uppercase to motion"
        },
        {
          "keys": "cc / C",
          "description": "Change entire line / to end of line"
        },
        {
          "keys": "ciw / cw",
          "description": "Change inner word / to end of word"
        },
        {
          "keys": "s / S",
          "description": "Substitute char / line (then insert)"
        },
        {
          "keys": "xp",
          "description": "Transpose two characters"
        },
        {
          "keys": "u / U",
          "description": "Undo / restore last changed line"
        },
        {
          "keys": "Ctrl + R",
          "description": "Redo"
        },
        {
          "keys": ".",
          "description": "Repeat last command"
        }
      ]
    },
    {
      "section": "Cut & Paste",
      "source": "vim.rtorr.com",
      "items": [
        {
          "keys": "yy / Y",
          "description": "Yank (copy) line / to end of line"
        },
        {
          "keys": "yiw / yaw",
          "description": "Yank inner word / word + surrounding space"
        },
        {
          "keys": "yw",
          "description": "Yank from cursor to start of next word"
        },
        {
          "keys": "p / P",
          "description": "Paste after / before cursor"
        },
        {
          "keys": "gp / gP",
          "description": "Paste after / before, leave cursor after"
        },
        {
          "keys": "dd / D",
          "description": "Delete (cut) line / to end of line"
        },
        {
          "keys": "diw / daw",
          "description": "Delete inner word / word + space"
        },
        {
          "keys": "dw",
          "description": "Delete to start of next word"
        },
        {
          "keys": "x",
          "description": "Delete character under cursor"
        },
        {
          "keys": ":3,5d",
          "description": "Delete lines 3 to 5"
        },
        {
          "keys": ":g/{pat}/d",
          "description": "Delete all lines matching pattern"
        },
        {
          "keys": ":g!/{pat}/d",
          "description": "Delete all lines NOT matching pattern"
        }
      ]
    },
    {
      "section": "Visual mode",
      "source": "vim.rtorr.com",
      "items": [
        {
          "keys": "v / V",
          "description": "Start char / linewise visual mode"
        },
        {
          "keys": "Ctrl + V",
          "description": "Start visual block mode"
        },
        {
          "keys": "o / O",
          "description": "Move to other end / corner of selection"
        },
        {
          "keys": "aw / ab / aB / at",
          "description": "Select word / () block / {} block / <> block"
        },
        {
          "keys": "ib / iB / it",
          "description": "Inner () / {} / <> block"
        },
        {
          "keys": "> / <",
          "description": "Indent / de-indent selection"
        },
        {
          "keys": "y / d",
          "description": "Yank / delete selection"
        },
        {
          "keys": "~ / u / U",
          "description": "Toggle / lower / uppercase selection"
        },
        {
          "keys": "Esc / Ctrl + C",
          "description": "Exit visual mode"
        }
      ]
    },
    {
      "section": "Indent",
      "source": "vim.rtorr.com",
      "items": [
        {
          "keys": ">> / <<",
          "description": "Indent / de-indent line"
        },
        {
          "keys": ">% / <%",
          "description": "Indent / de-indent () or {} block"
        },
        {
          "keys": ">ib / >at",
          "description": "Indent inner () / <> block"
        },
        {
          "keys": "3==",
          "description": "Re-indent 3 lines"
        },
        {
          "keys": "=iB / gg=G",
          "description": "Re-indent {} block / entire buffer"
        },
        {
          "keys": "]p",
          "description": "Paste and adjust indent"
        }
      ]
    },
    {
      "section": "Search & Replace",
      "source": "vim.rtorr.com",
      "items": [
        {
          "keys": "/{pattern}",
          "description": "Search forward for pattern"
        },
        {
          "keys": "?{pattern}",
          "description": "Search backward for pattern"
        },
        {
          "keys": "n / N",
          "description": "Next / prev search result"
        },
        {
          "keys": ":%s/old/new/g",
          "description": "Replace all in file"
        },
        {
          "keys": ":%s/old/new/gc",
          "description": "Replace all in file with confirmation"
        },
        {
          "keys": ":noh",
          "description": "Clear search highlight"
        },
        {
          "keys": ":vim /pat/ **/*",
          "description": "Search pattern in multiple files"
        },
        {
          "keys": ":cn / :cp",
          "description": "Next / prev quickfix match"
        },
        {
          "keys": ":cope / :ccl",
          "description": "Open / close quickfix window"
        }
      ]
    },
    {
      "section": "Registers & Marks",
      "source": "vim.rtorr.com",
      "items": [
        {
          "keys": ":reg",
          "description": "Show register contents"
        },
        {
          "keys": "\"xy / \"xp",
          "description": "Yank into / paste from register x"
        },
        {
          "keys": "\"+y / \"+p",
          "description": "Yank / paste system clipboard"
        },
        {
          "keys": ":marks",
          "description": "List all marks"
        },
        {
          "keys": "ma / `a",
          "description": "Set / jump to mark a"
        },
        {
          "keys": "`0 / `\"",
          "description": "Jump to last exit pos / last edit pos"
        },
        {
          "keys": "`` / Ctrl + O / Ctrl + I",
          "description": "Jump back / older / newer in jump list"
        },
        {
          "keys": ":changes / g; / g,",
          "description": "List changes / older / newer change pos"
        }
      ]
    },
    {
      "section": "Macros",
      "source": "vim.rtorr.com",
      "items": [
        {
          "keys": "qa / q",
          "description": "Record macro a / stop recording"
        },
        {
          "keys": "@a / @@",
          "description": "Run macro a / rerun last macro"
        }
      ]
    },
    {
      "section": "Tabs",
      "source": "vim.rtorr.com",
      "items": [
        {
          "keys": ":tabnew {file}",
          "description": "Open file in new tab"
        },
        {
          "keys": "gt / gT",
          "description": "Next / prev tab"
        },
        {
          "keys": "{N}gt",
          "description": "Go to tab N"
        },
        {
          "keys": ":tabm {N}",
          "description": "Move tab to position N"
        },
        {
          "keys": ":tabc / :tabo",
          "description": "Close current / all other tabs"
        },
        {
          "keys": ":tabdo {cmd}",
          "description": "Run command on all tabs"
        },
        {
          "keys": "Ctrl + WT",
          "description": "Move split into its own tab"
        }
      ]
    },
    {
      "section": "Windows & Buffers",
      "source": "vim.rtorr.com",
      "items": [
        {
          "keys": ":e {file}",
          "description": "Edit file in new buffer"
        },
        {
          "keys": ":bn / :bp",
          "description": "Next / prev buffer"
        },
        {
          "keys": ":bd",
          "description": "Delete buffer (close file)"
        },
        {
          "keys": ":ls / :buffers",
          "description": "List all open buffers"
        },
        {
          "keys": ":sp {file}",
          "description": "Open file in horizontal split"
        },
        {
          "keys": ":vs {file}",
          "description": "Open file in vertical split"
        },
        {
          "keys": "Ctrl + Ws / Ctrl + Wv",
          "description": "Split window horizontal / vertical"
        },
        {
          "keys": "Ctrl + Ww / Ctrl + Wq",
          "description": "Switch / quit window"
        },
        {
          "keys": "Ctrl + Wh/j/k/l",
          "description": "Move cursor to left/down/up/right window"
        },
        {
          "keys": "Ctrl + W=",
          "description": "Equalize window sizes"
        },
        {
          "keys": "Ctrl + WH/J/K/L",
          "description": "Move window to far left/bottom/top/right"
        }
      ]
    },
    {
      "section": "Folds & Diff",
      "source": "vim.rtorr.com",
      "items": [
        {
          "keys": "zf / zd / za",
          "description": "Create / delete / toggle fold"
        },
        {
          "keys": "zo / zc",
          "description": "Open / close fold"
        },
        {
          "keys": "zr / zm / zi",
          "description": "Open all / close all / toggle folding"
        },
        {
          "keys": "]c / [c",
          "description": "Next / prev diff change"
        },
        {
          "keys": "do / dp",
          "description": "Obtain / put diff from other buffer"
        },
        {
          "keys": ":diffthis / :diffo",
          "description": "Add to diff / turn off diff mode"
        }
      ]
    },
    {
      "section": "Exiting",
      "source": "vim.rtorr.com",
      "items": [
        {
          "keys": ":w",
          "description": "Save file"
        },
        {
          "keys": ":wq / :x / ZZ",
          "description": "Save and quit"
        },
        {
          "keys": ":q",
          "description": "Quit (fails if unsaved changes)"
        },
        {
          "keys": ":q! / ZQ",
          "description": "Quit and discard changes"
        },
        {
          "keys": ":wqa",
          "description": "Save and quit all tabs"
        },
        {
          "keys": ":w !sudo tee %",
          "description": "Save with sudo"
        }
      ]
    }
  ],
