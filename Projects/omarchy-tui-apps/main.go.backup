package main

import (
	"bufio"
	"bytes"
	"fmt"
	"os"
	"os/exec"
	"path/filepath"
	"slices"
	"sort"
	"strings"
	"syscall"
	"unicode"

	"github.com/mattn/go-runewidth"
)

// ── Icons (Nerd Font) ─────────────────────────────────────────────────────────
const (
	iconApp      = "󱗼" //"󰀻"
	iconTerminal = "" 
	iconFlatpak  = "󰏖"
	iconPrompt   = ""

	iconDisplayWidth = 3
)

func iconCell(icon string) string {
	return iconCellWidth(icon, iconDisplayWidth)
}

func iconCellWidth(icon string, displayWidth int) string {
	width := runewidth.StringWidth(icon)
	if width >= displayWidth {
		return icon
	}
	padding := displayWidth - width
	left := padding / 2
	right := padding - left
	return strings.Repeat(" ", left) + icon + strings.Repeat(" ", right)
}

func appIconCell() string {
	return iconCellWidth(iconApp, iconDisplayWidth+5)
}

// ── App entry ─────────────────────────────────────────────────────────────────

type App struct {
	// display
	Icon     string // one of the icon consts above
	Name     string
	SubTitle string // GenericName, then Comment
	// metadata (hidden from fzf display but used for search / launching)
	ID          string // desktop id  (dir-relative path, slashes→dashes, no .desktop)
	DesktopFile string // absolute path to .desktop file
	SearchText  string // name + subtitle + comment + id concatenated
	// raw fields (needed for launch)
	Exec     string
	Terminal bool
}

// fzfLine formats a tab-delimited row exactly as the original bash script:
//
//	col1: "ICON NAME"   (shown)
//	col2: subtitle      (shown)
//	col3: desktop-id    (hidden, used by preview & launch)
//	col4: desktop file  (hidden, used by preview & launch)
//	col5: search text   (hidden, searched by --nth)
func (a *App) fzfLine() string {
	return fmt.Sprintf("%s%s\t%s\t%s\t%s\t%s",
		iconCell(a.Icon), a.Name,
		a.SubTitle,
		a.ID,
		a.DesktopFile,
		a.SearchText,
	)
}

// ── Desktop file parser ───────────────────────────────────────────────────────

type desktopEntry struct {
	entryType  string
	name       string
	genericName string
	comment    string
	exec       string
	terminal   bool
	hidden     bool
	noDisplay  bool
	onlyShowIn []string
	notShowIn  []string
}

func parseDesktopFile(path string) (desktopEntry, bool) {
	f, err := os.Open(path)
	if err != nil {
		return desktopEntry{}, false
	}
	defer f.Close()

	var e desktopEntry
	inEntry := false
	sc := bufio.NewScanner(f)
	for sc.Scan() {
		line := strings.TrimRight(sc.Text(), "\r")
		if strings.HasPrefix(line, "[") {
			inEntry = line == "[Desktop Entry]"
			continue
		}
		if !inEntry {
			continue
		}
		idx := strings.IndexByte(line, '=')
		if idx < 0 {
			continue
		}
		key := strings.TrimSpace(line[:idx])
		val := strings.TrimSpace(line[idx+1:])

		switch key {
		case "Type":
			if e.entryType == "" {
				e.entryType = val
			}
		case "Name":
			if e.name == "" {
				e.name = val
			}
		case "GenericName":
			if e.genericName == "" {
				e.genericName = val
			}
		case "Comment":
			if e.comment == "" {
				e.comment = val
			}
		case "Exec":
			if e.exec == "" {
				e.exec = val
			}
		case "Terminal":
			if e.terminal == false {
				e.terminal = strings.EqualFold(val, "true")
			}
		case "Hidden":
			e.hidden = strings.EqualFold(val, "true")
		case "NoDisplay":
			e.noDisplay = strings.EqualFold(val, "true")
		case "OnlyShowIn":
			if e.onlyShowIn == nil {
				e.onlyShowIn = splitSemicolon(val)
			}
		case "NotShowIn":
			if e.notShowIn == nil {
				e.notShowIn = splitSemicolon(val)
			}
		}
	}
	return e, true
}

func splitSemicolon(s string) []string {
	parts := strings.Split(s, ";")
	out := parts[:0]
	for _, p := range parts {
		if p != "" {
			out = append(out, p)
		}
	}
	return out
}

// ── Scanner ───────────────────────────────────────────────────────────────────

type ScanConfig struct {
	HiddenIDs       map[string]bool
	CurrentDesktops []string
	IncludeTerminal bool
}

func desktopID(dir, path string) string {
	rel, _ := filepath.Rel(dir, path)
	rel = strings.TrimSuffix(rel, ".desktop")
	rel = strings.ReplaceAll(rel, "/", "-")
	return rel
}

func isFlatpakDir(dir string) bool {
	return strings.Contains(dir, "flatpak/exports/share/applications")
}

func desktopMatches(list []string, current []string) bool {
	for _, d := range current {
		if d == "" {
			continue
		}
		if slices.Contains(list, d) {
			return true
		}
	}
	return false
}

func isTerminalExec(exec string) bool {
	return strings.HasPrefix(exec, "xdg-terminal-exec") ||
		strings.Contains(exec, " xdg-terminal-exec ")
}

// scanDir walks one applications directory and returns (allApps, filteredApps).
// seenAll and seenFiltered track IDs already emitted across multiple scanDir calls.
func scanDir(dir string, cfg ScanConfig, seenAll, seenFiltered map[string]bool) (all, filtered []App) {
	entries, err := os.ReadDir(dir)
	if err != nil {
		return
	}

	isFP := isFlatpakDir(dir)

	var paths []string
	for _, e := range entries {
		if e.IsDir() {
			// recurse one level (applications/foo/bar.desktop is valid)
			sub := filepath.Join(dir, e.Name())
			subAll, subFiltered := scanDir(sub, cfg, seenAll, seenFiltered)
			all = append(all, subAll...)
			filtered = append(filtered, subFiltered...)
			continue
		}
		if strings.HasSuffix(e.Name(), ".desktop") {
			paths = append(paths, filepath.Join(dir, e.Name()))
		}
	}
	sort.Strings(paths)

	for _, path := range paths {
		e, ok := parseDesktopFile(path)
		if !ok {
			continue
		}
		// type defaults to Application
		if e.entryType != "" && e.entryType != "Application" {
			continue
		}
		if e.name == "" || e.exec == "" {
			continue
		}

		id := desktopID(dir, path)

		// Choose icon
		var icon string
		switch {
		case isFP:
			icon = iconFlatpak
		case e.terminal || isTerminalExec(e.exec):
			icon = iconTerminal
		default:
			icon = iconApp
		}

		sub := e.genericName
		if sub == "" {
			sub = e.comment
		}
		search := e.name + " " + sub + " " + e.comment + " " + id

		app := App{
			Icon:        icon,
			Name:        e.name,
			SubTitle:    sub,
			ID:          id,
			DesktopFile: path,
			SearchText:  search,
			Exec:        e.exec,
			Terminal:    e.terminal,
		}

		// ── ALL list (no filtering except terminal flag and dedup) ──────────
		if !seenAll[id] {
			seenAll[id] = true
			if cfg.IncludeTerminal || !e.terminal {
				all = append(all, app)
			}
		}

		// ── FILTERED list ──────────────────────────────────────────────────
		if seenFiltered[id] {
			continue
		}
		if cfg.HiddenIDs[id] {
			continue
		}
		if e.hidden || e.noDisplay {
			continue
		}
		if len(e.onlyShowIn) > 0 && !desktopMatches(e.onlyShowIn, cfg.CurrentDesktops) {
			continue
		}
		if len(e.notShowIn) > 0 && desktopMatches(e.notShowIn, cfg.CurrentDesktops) {
			continue
		}
		if !cfg.IncludeTerminal && e.terminal {
			continue
		}
		seenFiltered[id] = true
		filtered = append(filtered, app)
	}
	return
}

// ── Theme reader ──────────────────────────────────────────────────────────────

func readThemeColor(tomlPath, key, fallback string) string {
	f, err := os.Open(tomlPath)
	if err != nil {
		return fallback
	}
	defer f.Close()
	sc := bufio.NewScanner(f)
	for sc.Scan() {
		line := sc.Text()
		idx := strings.IndexByte(line, '=')
		if idx < 0 {
			continue
		}
		k := strings.TrimSpace(line[:idx])
		if k != key {
			continue
		}
		v := strings.TrimSpace(line[idx+1:])
		v = strings.Trim(v, `"`)
		v = strings.TrimFunc(v, func(r rune) bool {
			return r == '"' || unicode.IsSpace(r)
		})
		if v != "" {
			return v
		}
	}
	return fallback
}

// ── Hides file reader ─────────────────────────────────────────────────────────

func readHides(path string) map[string]bool {
	out := make(map[string]bool)
	f, err := os.Open(path)
	if err != nil {
		return out
	}
	defer f.Close()
	sc := bufio.NewScanner(f)
	for sc.Scan() {
		id := strings.TrimRight(sc.Text(), "\r\n")
		id = strings.TrimSuffix(id, ".desktop")
		if id != "" {
			out[id] = true
		}
	}
	return out
}

// ── Launch ────────────────────────────────────────────────────────────────────

func launchApp(id, desktopFile string) error {
	// 1. gtk-launch
	if p, err := exec.LookPath("gtk-launch"); err == nil {
		cmd := exec.Command(p, id)
		cmd.Stdout = nil
		cmd.Stderr = nil
		if err := cmd.Start(); err == nil {
			return nil
		}
	}
	// 2. gio
	if p, err := exec.LookPath("gio"); err == nil {
		cmd := exec.Command(p, "launch", desktopFile)
		cmd.Stdout = nil
		cmd.Stderr = nil
		if err := cmd.Start(); err == nil {
			return nil
		}
	}
	// 3. parse Exec= and run directly
	execLine := rawExec(desktopFile)
	if execLine == "" {
		return fmt.Errorf("no Exec= found in %s", desktopFile)
	}
	// strip field codes (%f %F %u %U etc.)
	parts := strings.Fields(execLine)
	var cleaned []string
	for _, p := range parts {
		if len(p) == 2 && p[0] == '%' {
			continue
		}
		cleaned = append(cleaned, p)
	}
	if len(cleaned) == 0 {
		return fmt.Errorf("empty exec line")
	}
	cmd := exec.Command(cleaned[0], cleaned[1:]...)
	cmd.SysProcAttr = &syscall.SysProcAttr{Setsid: true}
	cmd.Stdout = nil
	cmd.Stderr = nil
	return cmd.Start()
}

func rawExec(desktopFile string) string {
	f, err := os.Open(desktopFile)
	if err != nil {
		return ""
	}
	defer f.Close()
	sc := bufio.NewScanner(f)
	for sc.Scan() {
		line := strings.TrimRight(sc.Text(), "\r")
		if strings.HasPrefix(line, "Exec=") {
			return strings.TrimPrefix(line, "Exec=")
		}
	}
	return ""
}

// ── Preview ───────────────────────────────────────────────────────────────────

// runPreview prints the preview panel for a given desktop file.
// Called when OMARCHY_APPS_PREVIEW env var is set (fzf preview sub-process).
func runPreview(desktopFile, title, subtitle, id string) {
	f, err := os.Open(desktopFile)
	if err != nil {
		fmt.Printf("\n  (cannot open %s)\n", desktopFile)
		return
	}
	defer f.Close()

	vals := map[string]string{}
	inEntry := false
	sc := bufio.NewScanner(f)
	for sc.Scan() {
		line := strings.TrimRight(sc.Text(), "\r")
		if strings.HasPrefix(line, "[") {
			inEntry = line == "[Desktop Entry]"
			continue
		}
		if !inEntry {
			continue
		}
		idx := strings.IndexByte(line, '=')
		if idx < 0 {
			continue
		}
		k := strings.TrimSpace(line[:idx])
		if _, seen := vals[k]; !seen {
			vals[k] = strings.TrimSpace(line[idx+1:])
		}
	}

	get := func(k string) string {
		if v, ok := vals[k]; ok && v != "" {
			return v
		}
		return "-"
	}

	title = strings.TrimSpace(title)
	subtitle = strings.TrimSpace(subtitle)

	fmt.Println()
	fmt.Printf("  %s\n", title)
	if subtitle != "" && subtitle != "-" {
		fmt.Printf("  %s\n", subtitle)
	}
	fmt.Println()
	fmt.Printf("  %-10s %s\n", "Type", get("Type"))
	fmt.Printf("  %-10s %s\n", "Terminal", get("Terminal"))
	fmt.Printf("  %-10s %s\n", "ID", id)
	fmt.Println()
	fmt.Println("  Exec")
	fmt.Printf("  %s\n", get("Exec"))
	fmt.Println()
	fmt.Println("  Comment")
	fmt.Printf("  %s\n", get("Comment"))
	fmt.Println()
	fmt.Println("  Desktop file")
	fmt.Printf("  %s\n", desktopFile)
}

// ── Toggle helper ─────────────────────────────────────────────────────────────

// runToggle is called when OMARCHY_APPS_TOGGLE is set.
// It reads the state file, flips state, then prints one fzf action line:
//   reload(BINARY --list [--all])+change-header(NEW HEADER)
func runToggle(stateFile, binary, filteredList, allList string) {
	raw, _ := os.ReadFile(stateFile)
	current := strings.TrimSpace(string(raw))

	var newState, listFlag, headerText string
	if current == "0" {
		newState = "1"
		listFlag = "--all"
		headerText = buildHeader(true)
	} else {
		newState = "0"
		listFlag = ""
		headerText = buildHeader(false)
	}
	os.WriteFile(stateFile, []byte(newState), 0600)

	// The reload command re-runs this binary in --list mode
	reloadCmd := binary + " --list"
	if listFlag != "" {
		reloadCmd += " " + listFlag
	}
	reloadCmd += " " + filteredList + " " + allList

	// Single action-spec line consumed by fzf transform
	fmt.Printf("reload(%s)+change-header(%s)", reloadCmd, headerText)
}

// ── List printer (called by reload inside fzf) ────────────────────────────────

// runList prints pre-built tab-lines from a file in their stored order.
// The lines were written at startup, so reloads can reuse the same icon and
// category formatting without re-scanning desktop files or reshuffling rows.
func runList(path string) {
	data, err := os.ReadFile(path)
	if err != nil {
		return
	}
	lines := strings.Split(strings.TrimRight(string(data), "\n"), "\n")
	for _, l := range lines {
		if l != "" {
			fmt.Println(l)
		}
	}
}

// ── Header ────────────────────────────────────────────────────────────────────

func buildHeader(showingAll bool) string {
	appIcon := appIconCell()
	termIcon := iconCell(iconTerminal)
	fpIcon := iconCell(iconFlatpak)
	if showingAll {
		return fmt.Sprintf("%sApps  %sFlatpaks  %sTerminal  \033[2m[Ctrl+H: Show filtered]\033[0m",
			appIcon, fpIcon, termIcon)
	}
	return fmt.Sprintf("%sApps  %sFlatpaks  %sTerminal  \033[2m[Ctrl+H: Show all]\033[0m",
		appIcon, fpIcon, termIcon)
}

// ── Main ──────────────────────────────────────────────────────────────────────

func main() {
	args := os.Args[1:]

	// ── Sub-commands (called internally by fzf) ───────────────────────────
	// These are low-overhead fast paths; they do not re-scan .desktop files.

	// Preview sub-process: BINARY --preview DESKTOP_FILE TITLE SUBTITLE ID
	if len(args) >= 1 && args[0] == "--preview" {
		if len(args) < 5 {
			os.Exit(1)
		}
		runPreview(args[1], args[2], args[3], args[4])
		return
	}

	// Toggle sub-process: BINARY --toggle STATE_FILE FILTERED_LIST ALL_LIST
	if len(args) >= 1 && args[0] == "--toggle" {
		if len(args) < 4 {
			os.Exit(1)
		}
		runToggle(args[1], os.Args[0], args[2], args[3])
		return
	}

	// List printer: BINARY --list [--all] FILTERED_LIST ALL_LIST
	if len(args) >= 1 && args[0] == "--list" {
		rest := args[1:]
		showAll := false
		if len(rest) > 0 && rest[0] == "--all" {
			showAll = true
			rest = rest[1:]
		}
		if len(rest) < 2 {
			os.Exit(1)
		}
		if showAll {
			runList(rest[1]) // all list file
		} else {
			runList(rest[0]) // filtered list file
		}
		return
	}

	// ── Normal launcher startup ───────────────────────────────────────────

	showAll := false
	for _, a := range args {
		if a == "-a" || a == "--all" {
			showAll = true
		}
	}

	home := os.Getenv("HOME")

	// Config paths
	themeFile := envOr("OMARCHY_THEME_COLORS",
		filepath.Join(home, ".config/omarchy/current/theme/colors.toml"))
	hidesFile := envOr("OMARCHY_LAUNCHER_HIDES",
		filepath.Join(home, ".local/share/omarchy/default/omarchy/launcher.hides"))
	includeTerminal := envOr("INCLUDE_TERMINAL_APPS", "true") == "true"

	// Current desktop envs
	desktopEnv := envOr("XDG_CURRENT_DESKTOP",
		envOr("XDG_SESSION_DESKTOP", envOr("DESKTOP_SESSION", "")))
	currentDesktops := strings.Split(desktopEnv, ":")

	hiddenIDs := readHides(hidesFile)

	cfg := ScanConfig{
		HiddenIDs:       hiddenIDs,
		CurrentDesktops: currentDesktops,
		IncludeTerminal: includeTerminal,
	}

	// Build search dirs
	dataDirs := strings.Split(envOr("XDG_DATA_DIRS", "/usr/local/share:/usr/share"), ":")
	var scanDirs []string
	scanDirs = append(scanDirs, filepath.Join(home, ".local/share/applications"))
	for _, d := range dataDirs {
		scanDirs = append(scanDirs, filepath.Join(d, "applications"))
	}
	scanDirs = append(scanDirs,
		filepath.Join(home, ".nix-profile/share/applications"),
		"/var/lib/flatpak/exports/share/applications",
		filepath.Join(home, ".local/share/flatpak/exports/share/applications"),
	)

	seenAll := map[string]bool{}
	seenFiltered := map[string]bool{}

	var allApps, filteredApps []App
	for _, dir := range scanDirs {
		a, f := scanDir(dir, cfg, seenAll, seenFiltered)
		allApps = append(allApps, a...)
		filteredApps = append(filteredApps, f...)
	}

	if len(allApps) == 0 && len(filteredApps) == 0 {
		fmt.Fprintln(os.Stderr, "No launchable desktop applications found.")
		os.Exit(1)
	}

	// Sort by name A→Z, case-insensitive, stable so equal names keep their
	// original scan order.
	sortApps := func(apps []App) {
		sort.SliceStable(apps, func(i, j int) bool {
			return strings.ToLower(apps[i].Name) < strings.ToLower(apps[j].Name)
		})
	}
	sortApps(allApps)
	sortApps(filteredApps)

	// Write lists to temp files (reused by --list and --toggle sub-commands)
	filteredFile, err := writeTempList(filteredApps)
	if err != nil {
		fmt.Fprintln(os.Stderr, "error writing filtered list:", err)
		os.Exit(1)
	}
	allFile, err := writeTempList(allApps)
	if err != nil {
		fmt.Fprintln(os.Stderr, "error writing all list:", err)
		os.Exit(1)
	}
	defer os.Remove(filteredFile)
	defer os.Remove(allFile)

	// State file: "0" = filtered, "1" = all
	stateFile, err := os.CreateTemp("", "omarchy-apps-state-*")
	if err != nil {
		fmt.Fprintln(os.Stderr, "error creating state file:", err)
		os.Exit(1)
	}
	initialState := "0"
	if showAll {
		initialState = "1"
	}
	stateFile.WriteString(initialState)
	stateFile.Close()
	defer os.Remove(stateFile.Name())

	// Theme colours
	fg := readThemeColor(themeFile, "foreground", "#c0caf5")
	bg := readThemeColor(themeFile, "background", "#1a1b26")
	accent := readThemeColor(themeFile, "accent", "#7aa2f7")
	selBg := readThemeColor(themeFile, "color0", bg)
	muted := readThemeColor(themeFile, "color8", fg)

	// Resolve to absolute path so fzf sub-processes (toggle, list, preview)
	// can be called regardless of the working directory fzf runs in.
	self, err := filepath.Abs(os.Args[0])
	if err != nil {
		self = os.Args[0]
	}

	initialHeader := buildHeader(showAll)

	// fzf arguments — identical structure to the original bash script
	fzfArgs := []string{
		"--style", "full",
		"--layout", "reverse",
		"--border", "rounded",
		"--prompt", iconPrompt + " Apps  ",
		"--header-first",
		"--header", initialHeader,
		"--delimiter", "\t",
		"--with-nth", "1,2",
		"--nth", "1,2,3,5",
		"--no-multi",
		"--ansi",
		"--preview", fmt.Sprintf("%s --preview {4} {1} {2} {3}", self),
		"--preview-window", "right,46%,border-left,wrap",
		"--color", fmt.Sprintf("fg:%s,bg:%s,hl:%s,fg+:%s,bg+:%s,hl+:%s",
			fg, bg, accent, fg, selBg, accent),
		"--color", fmt.Sprintf("prompt:%s,pointer:%s,marker:%s,spinner:%s,header:%s,border:%s,preview-border:%s,info:%s",
			accent, accent, accent, accent, muted, muted, muted, accent),
		// Single transform — atomic: flips state + reloads list + updates header
		"--bind", fmt.Sprintf("ctrl-h:transform(%s --toggle %s %s %s)",
			self, stateFile.Name(), filteredFile, allFile),
	}

	if h := os.Getenv("APPS_FZF_HEIGHT"); h != "" {
		fzfArgs = append(fzfArgs, "--height", h)
	}

	// Pipe initial list into fzf
	var initialList []App
	if showAll {
		initialList = allApps
	} else {
		initialList = filteredApps
	}

	var buf bytes.Buffer
	for _, a := range initialList {
		buf.WriteString(a.fzfLine())
		buf.WriteByte('\n')
	}

	fzfCmd := exec.Command("fzf", fzfArgs...)
	fzfCmd.Stdin = &buf
	fzfCmd.Stderr = os.Stderr

	out, err := fzfCmd.Output()
	if err != nil {
		// user pressed Esc / Ctrl-C — normal exit
		os.Exit(0)
	}

	selected := strings.TrimRight(string(out), "\n")
	if selected == "" {
		os.Exit(0)
	}

	// Parse tab-separated output: col3=id, col4=desktop file
	cols := strings.Split(selected, "\t")
	if len(cols) < 4 {
		os.Exit(0)
	}
	id := cols[2]
	desktopFile := cols[3]

	if err := launchApp(id, desktopFile); err != nil {
		fmt.Fprintln(os.Stderr, "launch error:", err)
		os.Exit(1)
	}
}

// ── Helpers ───────────────────────────────────────────────────────────────────

func envOr(key, def string) string {
	if v := os.Getenv(key); v != "" {
		return v
	}
	return def
}

func writeTempList(apps []App) (string, error) {
	f, err := os.CreateTemp("", "omarchy-apps-list-*")
	if err != nil {
		return "", err
	}
	defer f.Close()
	w := bufio.NewWriter(f)
	for _, a := range apps {
		w.WriteString(a.fzfLine())
		w.WriteByte('\n')
	}
	return f.Name(), w.Flush()
}